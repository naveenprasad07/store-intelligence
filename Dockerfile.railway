FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi==0.111.0 \
    "uvicorn[standard]==0.30.1" \
    redis==5.0.4 \
    pydantic==2.7.1 \
    pydantic-settings==2.2.1 \
    python-multipart==0.0.9

COPY app/ ./app/
COPY store_layout.json .

ENV PYTHONPATH=/app

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
